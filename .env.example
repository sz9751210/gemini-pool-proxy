# =========================================================================
# Gemini Pool Proxy - 環境變數設定檔範例
# 
# 啟動 Desktop 應用前，請將此檔案複製並重新命名為 .env
# =========================================================================

# -------------------------------------------------------------------------
# [必填] 基礎安全與驗證設定
# -------------------------------------------------------------------------

# 管理員驗證權杖 (Auth Token)
# 用於保護本機桌面端登入及所有 /api/v1/* 的管理介面調用。
AUTH_TOKEN=sk-admin-123456

# 允許調用代理 API 的權杖清單 (Allowed Tokens)
# 當客戶端使用 Claude Code 或 curl 訪問 /v1/chat/completions 時所需攜帶的 Bearer Token。
# 以 JSON 陣列格式填寫多個允許的 Token。
ALLOWED_TOKENS='["sk-user-123456","sk-user-654321"]'

# 真實的 Google Gemini API Keys
# 您在 Google AI Studio 申請的實際 API 金鑰。Proxy 將會使用這些金鑰對 Google 伺服器發起真實請求。
# 以 JSON 陣列格式填寫。系統會在這些 key 之間進行負載平衡與輪替。
API_KEYS='["AIzaSy_your_key_1","AIzaSy_your_key_2"]'

# -------------------------------------------------------------------------
# [進階] 模型池模型配置 (Model Pools)
# -------------------------------------------------------------------------

# 自定義模型池映射關係
# 您可以將一個自訂名稱(如 claude-sonnet)對應到多個實際的連線模型名稱，達到隱蔽與備援的效果。
# 支援 JSON 格式：{"alias":["model-1","model-2"]} 
# (配置後客戶端呼叫 claude-sonnet 即自動被轉換)。
MODEL_POOLS='{"claude-sonnet":["gemini-2.5-pro"],"fast":["gemini-2.5-flash","gemma-3-4b-it"]}'

# Model Pool 輪詢策略
# 可為: round_robin (每次依序切換模型) / least_used (優先使用目前呼叫次數較少的模型)
MODEL_POOL_STRATEGY=round_robin

# Model Pool 輪詢作用範圍
# 可為: global (全域共用同一游標) / token (每個使用者 token 各自輪詢)
MODEL_POOL_SCOPE=global

# 定義具有「思考 (Thinking)」能力的模型清單
THINKING_MODELS='["gemini-2.5-flash","gemini-2.5-pro"]'

# 定義具有「網頁搜尋 (Search)」能力的模型清單
SEARCH_MODELS='["gemini-2.5-flash","gemini-2.5-pro"]'

# 定義支援圖像理解或生成的模型清單
IMAGE_MODELS='["gemini-2.0-flash-exp","gemini-2.5-flash-image-preview"]'

# 定義支援 URL 上下文解析的模型清單
URL_CONTEXT_MODELS='["gemini-2.5-pro","gemini-2.5-flash","gemini-2.5-flash-lite","gemini-2.0-flash"]'

# 過濾(停用)的模型清單。當客戶端請求這些模型時，Proxy 會直接阻斷。
FILTERED_MODELS='["gemini-1.0-pro-vision-latest","gemini-pro-vision","chat-bison-001","text-bison-001"]'

# -------------------------------------------------------------------------
# [選填] 代理與連線行為控制
# -------------------------------------------------------------------------

# 金鑰池負載平衡策略
# 可為: round_robin (依序輪替, 預設) / random (隨機) / least_fail (最少失敗優先)
POOL_STRATEGY=round_robin

# 允許單一 API Key 的最大連續失敗次數 (超過此數將進入 Cooldown 冷卻期)
MAX_FAILURES=3

# API Key 在發生連線錯誤或超過速率限制(Rate Limit)被封鎖後的冷卻時間 (秒)
COOLDOWN_SECONDS=60

# 是否開啟 OpenAI 相容模式
# 設為 true (預設值) 將自動且透明地將各種 OpenAI Client 的 payload 轉換為原生 Gemini 格式。
COMPAT_MODE=true

# -------------------------------------------------------------------------
# [選填] 網路連接埠 (Ports) 與伺服器設定
# -------------------------------------------------------------------------

# Proxy Server 綁定的 IP (為維持安全性，預設僅綁定本機 localhost，禁止外部存取)
RUNTIME_BIND_HOST=127.0.0.1

# Proxy Server 嘗試監聽的本地連接埠範圍 (start to end)
# 如果 port_start 被佔用，系統會自動在範圍內尋找下一個空閒埠。
RUNTIME_PORT_START=18080
RUNTIME_PORT_END=18099

# Dashboard 前端開發所使用的 Vite Port
VITE_DEV_PORT=1420

# 網頁端登入狀態的 Cookie 名稱
SESSION_COOKIE_NAME=gb_session
